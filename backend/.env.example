# ─── EarthMind X Backend Environment ─────────────────────────────────────────
# Copy to .env for development

NODE_ENV=development
PORT=3001

# PostgreSQL — local (dev) or Neon (production)
DATABASE_URL=postgresql://earthmind:earthmind_dev@localhost:5432/earthmind_x
# DATABASE_URL=postgresql://user:pass@host.neon.tech/earthmind_x?sslmode=require

# AI Service URL
AI_SERVICE_URL=http://localhost:8000
# AI_SERVICE_URL=https://earthmind-ai.onrender.com

# CORS — allow the frontend origin
CORS_ORIGIN=http://localhost:5173
# CORS_ORIGIN=https://earthmind-x.vercel.app
