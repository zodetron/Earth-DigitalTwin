PORT=8000

# PostgreSQL — local (dev) or Neon (production)
DATABASE_URL=postgresql://earthmind:earthmind_dev@localhost:5432/earthmind_x
# DATABASE_URL=postgresql://user:pass@host.neon.tech/earthmind_x?sslmode=require

# Anthropic API Key — required for EarthGPT and Emergency Commander
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Dataset paths — only needed for initial seeding (not used in production)
DATASETS_PATH=/path/to/ZUUP_DataSets
MODELS_PATH=./models
