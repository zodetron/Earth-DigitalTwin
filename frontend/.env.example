# ─── EarthMind X Frontend Environment ───────────────────────────────────────
# Copy to .env.local for development

# Development (Vite proxy handles routing — leave empty or set to localhost)
VITE_API_URL=http://localhost:3001
VITE_AI_SERVICE_URL=http://localhost:8000

# Production (set these in Vercel project settings)
# VITE_API_URL=https://earthmind-backend.onrender.com
# VITE_AI_SERVICE_URL=https://earthmind-ai.onrender.com
